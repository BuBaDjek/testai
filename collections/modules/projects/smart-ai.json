        {
          "name": "Проверить создание проекта с неуникальным именем",
          "description": "Тест-кейс: Проверка ошибки при создании проекта AI Текст с уже существующим именем",
          "item": [
            {
              "name": "STEP 1 - GET /api/Projects (Получить список проектов до создания)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "// =========================================",
                      "// STEP 1: Получаем список проектов и запоминаем количество",
                      "// Имя проекта должно быть уникальным ВСЕГДА, независимо от типа (component)",
                      "// =========================================",
                      "",
                      "pm.test('Status 200 - Список проектов получен', function () {",
                      "    pm.response.to.have.status(200);",
                      "});",
                      "",
                      "var json = pm.response.json();",
                      "",
                      "pm.test('Response is valid JSON with result array', function () {",
                      "    pm.expect(json).to.be.an('object');",
                      "    pm.expect(json.result).to.be.an('array');",
                      "});",
                      "",
                      "// Сохраняем количество проектов до создания",
                      "var projectCount = json.result ? json.result.length : 0;",
                      "pm.environment.set('aiProjectCountBefore', projectCount);",
                      "",
                      "// Берём имя ЛЮБОГО существующего проекта (имя уникально глобально)",
                      "var allProjects = json.result || [];",
                      "",
                      "console.log('Total projects before: ' + projectCount);",
                      "console.log('All projects count: ' + allProjects.length);",
                      "",
                      "if (allProjects.length > 0) {",
                      "    // Выбираем первый проект с валидным именем (без пробелов и спецсимволов)",
                      "    var validName = null;",
                      "    for (var i = 0; i < allProjects.length; i++) {",
                      "        var proj = allProjects[i];",
                      "        // Проверяем что имя подходит под regex: буквы, цифры, дефис, подчёркивание, точка",
                      "        if (proj.name && /^[а-яА-Яa-zA-Z0-9@\\\\_\\-\\.]+$/.test(proj.name)) {",
                      "            validName = proj.name;",
                      "            console.log('Found valid existing project name: ' + validName);",
                      "            break;",
                      "        }",
                      "    }",
                      "    ",
                      "    if (validName) {",
                      "        pm.environment.set('aiExistingProjectName', validName);",
                      "        console.log('Will use existing project name: ' + validName);",
                      "    } else {",
                      "        // Если нет валидного имени, используем первое и логируем",
                      "        pm.environment.set('aiExistingProjectName', allProjects[0].name);",
                      "        console.log('Using first project name (may have invalid chars): ' + allProjects[0].name);",
                      "    }",
                      "} else {",
                      "    console.log('No existing projects found - test may not work correctly');",
                      "}"
                    ]
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Accept", "value": "application/json, text/plain, */*" }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/Projects?pageSize=100&pageNumber=0",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "Projects"],
                  "query": [
                    { "key": "pageSize", "value": "100" },
                    { "key": "pageNumber", "value": "0" }
                  ]
                }
              }
            },
            {
              "name": "STEP 2 - POST /api/Projects (Попытка создать проект с существующим именем)",
              "event": [
                {
                  "listen": "prerequest",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "// Используем имя существующего проекта, если есть",
                      "var existingName = pm.environment.get('aiExistingProjectName');",
                      "if (!existingName) {",
                      "    existingName = 'Тестовый проект AI'; // Fallback имя",
                      "}",
                      "pm.environment.set('aiDuplicateProjectName', existingName);",
                      "console.log('Attempting to create project with existing name: ' + existingName);"
                    ]
                  }
                },
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "// =========================================",
                      "// STEP 2: Проверяем что создание дубликата возвращает ошибку",
                      "// =========================================",
                      "",
                      "pm.test('Status 400 - Ошибка при создании проекта с неуникальным именем', function () {",
                      "    pm.response.to.have.status(400);",
                      "});",
                      "",
                      "pm.test('Error response contains message', function () {",
                      "    try {",
                      "        var json = pm.response.json();",
                      "        console.log('Error response: ' + JSON.stringify(json));",
                      "        pm.expect(json).to.be.an('object');",
                      "        // Проверяем наличие сообщения об ошибке",
                      "        pm.expect(json.message || json.error || json.title || JSON.stringify(json)).to.be.a('string');",
                      "    } catch (e) {",
                      "        var text = pm.response.text();",
                      "        console.log('Error response text: ' + text);",
                      "        pm.expect(text).to.be.a('string').and.not.empty;",
                      "    }",
                      "});",
                      "",
                      "console.log('Duplicate project creation correctly rejected with 400 error');"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Accept", "value": "application/json, text/plain, */*" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"{{aiDuplicateProjectName}}\",\n  \"description\": \"\",\n  \"component\": 1\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": "{{baseUrl}}/api/Projects"
              }
            },
            {
              "name": "STEP 3 - GET /api/Projects (Проверить что список не изменился)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "// =========================================",
                      "// STEP 3: Проверяем что количество проектов не изменилось",
                      "// =========================================",
                      "",
                      "pm.test('Status 200 - Список проектов получен', function () {",
                      "    pm.response.to.have.status(200);",
                      "});",
                      "",
                      "var json = pm.response.json();",
                      "",
                      "pm.test('Project count unchanged after failed creation', function () {",
                      "    var countBefore = pm.environment.get('aiProjectCountBefore');",
                      "    var countAfter = json.result ? json.result.length : 0;",
                      "    ",
                      "    console.log('Projects before: ' + countBefore);",
                      "    console.log('Projects after: ' + countAfter);",
                      "    ",
                      "    pm.expect(countAfter).to.equal(parseInt(countBefore));",
                      "});",
                      "",
                      "pm.test('Response structure is valid', function () {",
                      "    pm.expect(json).to.be.an('object');",
                      "    pm.expect(json.result).to.be.an('array');",
                      "});",
                      "",
                      "// Очистка переменных",
                      "pm.environment.unset('aiProjectCountBefore');",
                      "pm.environment.unset('aiExistingProjects');",
                      "pm.environment.unset('aiExistingProjectName');",
                      "pm.environment.unset('aiDuplicateProjectName');",
                      "",
                      "console.log('Cleanup completed - all test variables removed');"
                    ]
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Accept", "value": "application/json, text/plain, */*" }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/Projects?pageSize=100&pageNumber=0",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "Projects"],
                  "query": [
                    { "key": "pageSize", "value": "100" },
                    { "key": "pageNumber", "value": "0" }
                  ]
                }
              }
            }
          ]
        },
        {
          "name": "Проверить возможность создания, редактирования, удаления проекта",
          "description": "Тест-кейс: Создание проекта AI Текст (Задачи NLP), редактирование и удаление",
          "item": [
            {
              "name": "STEP 1 - POST /api/Projects (Создание проекта)",
              "event": [
                {
                  "listen": "prerequest",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "// Генерируем уникальное имя проекта",
                      "var timestamp = Date.now();",
                      "var projectName = 'NLP_Test_' + timestamp;",
                      "pm.environment.set('nlpProjectName', projectName);",
                      "pm.environment.set('nlpProjectDesc', 'Тестовый проект Задачи NLP для автотестов');",
                      "console.log('Creating NLP project: ' + projectName);"
                    ]
                  }
                },
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "// =========================================",
                      "// STEP 1: Создание проекта",
                      "// =========================================",
                      "",
                      "pm.test('Status 201 - Проект NLP создан', function () {",
                      "    pm.response.to.have.status(201);",
                      "});",
                      "",
                      "pm.test('Response contains project ID', function () {",
                      "    var responseText = pm.response.text();",
                      "    pm.expect(responseText).to.be.a('string').and.not.empty;",
                      "    var projectId = parseInt(responseText, 10);",
                      "    pm.expect(projectId).to.be.a('number').and.above(0);",
                      "    pm.environment.set('nlpProjectId', projectId);",
                      "    console.log('Created NLP project with ID: ' + projectId);",
                      "});"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Accept", "value": "application/json, text/plain, */*" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"{{nlpProjectName}}\",\n  \"description\": \"{{nlpProjectDesc}}\",\n  \"component\": 1\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": "{{baseUrl}}/api/Projects"
              }
            },
            {
              "name": "STEP 2 - GET /api/Projects/{id} (Проверка создания)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "// =========================================",
                      "// STEP 2: Проверка что проект создан корректно",
                      "// =========================================",
                      "",
                      "pm.test('Status 200 - Проект найден', function () {",
                      "    pm.response.to.have.status(200);",
                      "});",
                      "",
                      "var json = pm.response.json();",
                      "var projectName = pm.environment.get('nlpProjectName');",
                      "var projectDesc = pm.environment.get('nlpProjectDesc');",
                      "",
                      "pm.test('Project name matches', function () {",
                      "    pm.expect(json.name).to.equal(projectName);",
                      "});",
                      "",
                      "pm.test('Project description matches', function () {",
                      "    pm.expect(json.description).to.equal(projectDesc);",
                      "});",
                      "",
                      "pm.test('Project component is NLP (1)', function () {",
                      "    pm.expect(json.component).to.equal(1);",
                      "});",
                      "",
                      "console.log('Project verified: name=' + json.name + ', component=' + json.component);"
                    ]
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Accept", "value": "application/json, text/plain, */*" }
                ],
                "url": "{{baseUrl}}/api/Projects/{{nlpProjectId}}"
              }
            },
            {
              "name": "STEP 3 - PUT /api/Projects/{id} (Редактирование проекта)",
              "event": [
                {
                  "listen": "prerequest",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "// Новые данные для редактирования",
                      "var timestamp = Date.now();",
                      "var newName = 'NLP_Edited_' + timestamp;",
                      "var newDesc = 'Отредактированный проект Задачи NLP';",
                      "pm.environment.set('nlpEditedName', newName);",
                      "pm.environment.set('nlpEditedDesc', newDesc);",
                      "console.log('Updating project to: ' + newName);"
                    ]
                  }
                },
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "// =========================================",
                      "// STEP 3: Редактирование проекта",
                      "// =========================================",
                      "",
                      "pm.test('Status 200 - Проект обновлён', function () {",
                      "    pm.response.to.have.status(200);",
                      "});",
                      "",
                      "// PUT может вернуть пустой ответ, проверяем статус",
                      "var responseText = pm.response.text();",
                      "console.log('PUT response: ' + responseText);",
                      "",
                      "if (responseText && responseText.trim().length > 0) {",
                      "    try {",
                      "        var json = JSON.parse(responseText);",
                      "        var newName = pm.environment.get('nlpEditedName');",
                      "        var newDesc = pm.environment.get('nlpEditedDesc');",
                      "        ",
                      "        pm.test('Updated name matches', function () {",
                      "            pm.expect(json.name).to.equal(newName);",
                      "        });",
                      "        ",
                      "        pm.test('Updated description matches', function () {",
                      "            pm.expect(json.description).to.equal(newDesc);",
                      "        });",
                      "        console.log('Project updated: ' + json.name);",
                      "    } catch (e) {",
                      "        console.log('Response is not JSON, status check passed');",
                      "    }",
                      "} else {",
                      "    console.log('Empty response, status check passed');",
                      "}"
                    ]
                  }
                }
              ],
              "request": {
                "method": "PUT",
                "header": [
                  { "key": "Accept", "value": "application/json, text/plain, */*" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"id\": {{nlpProjectId}},\n  \"name\": \"{{nlpEditedName}}\",\n  \"description\": \"{{nlpEditedDesc}}\",\n  \"component\": 1\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": "{{baseUrl}}/api/Projects/{{nlpProjectId}}"
              }
            },
            {
              "name": "STEP 4 - GET /api/Projects/{id} (Проверка редактирования)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "// =========================================",
                      "// STEP 4: Проверка что изменения применились",
                      "// =========================================",
                      "",
                      "pm.test('Status 200 - Проект найден', function () {",
                      "    pm.response.to.have.status(200);",
                      "});",
                      "",
                      "var json = pm.response.json();",
                      "var newName = pm.environment.get('nlpEditedName');",
                      "var newDesc = pm.environment.get('nlpEditedDesc');",
                      "",
                      "pm.test('Name updated correctly', function () {",
                      "    pm.expect(json.name).to.equal(newName);",
                      "});",
                      "",
                      "pm.test('Description updated correctly', function () {",
                      "    pm.expect(json.description).to.equal(newDesc);",
                      "});",
                      "",
                      "pm.test('Component still NLP (1)', function () {",
                      "    pm.expect(json.component).to.equal(1);",
                      "});",
                      "",
                      "console.log('Verified edited project: ' + json.name);"
                    ]
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Accept", "value": "application/json, text/plain, */*" }
                ],
                "url": "{{baseUrl}}/api/Projects/{{nlpProjectId}}"
              }
            },
            {
              "name": "STEP 5 - DELETE /api/Projects/{id} (Удаление проекта)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "// =========================================",
                      "// STEP 5: Удаление проекта (TEARDOWN)",
                      "// =========================================",
                      "",
                      "var projectId = pm.environment.get('nlpProjectId');",
                      "",
                      "pm.test('Status 2xx - Проект удалён', function () {",
                      "    pm.expect(pm.response.code).to.be.at.least(200).and.below(300);",
                      "});",
                      "",
                      "console.log('Deleted NLP project ID: ' + projectId);",
                      "",
                      "// Очистка переменных",
                      "pm.environment.unset('nlpProjectId');",
                      "pm.environment.unset('nlpProjectName');",
                      "pm.environment.unset('nlpProjectDesc');",
                      "pm.environment.unset('nlpEditedName');",
                      "pm.environment.unset('nlpEditedDesc');",
                      "",
                      "console.log('Cleanup completed - all test variables removed');"
                    ]
                  }
                }
              ],
              "request": {
                "method": "DELETE",
                "header": [
                  { "key": "Accept", "value": "application/json, text/plain, */*" }
                ],
                "url": "{{baseUrl}}/api/Projects/{{nlpProjectId}}"
              }
            }
          ]
        }
      ]
    }
