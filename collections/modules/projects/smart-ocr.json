          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json, text/plain, */*"
              }
            ],
            "url": "{{baseUrl}}/api/Projects/{{createdProjectId}}"
          }
        },
        {
          "name": "VERIFY - Проверка схемы разметки создана автоматически",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// =========================================",
                  "// VERIFY: Проверка автоматического создания схемы разметки",
                  "// =========================================",
                  "",
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is JSON', function () {",
                  "    pm.expect(function () { pm.response.json(); }).to.not.throw();",
                  "});",
                  "",
                  "var json = pm.response.json();",
                  "",
                  "pm.test('Marking schemes returned', function () {",
                  "    pm.expect(json.result).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('At least one marking scheme exists', function () {",
                  "    pm.expect(json.result.length).to.be.at.least(1);",
                  "});",
                  "",
                  "if (json.result.length > 0) {",
                  "    var scheme = json.result[0];",
                  "    pm.environment.set('createdMarkingSchemeId', scheme.id);",
                  "    ",
                  "    pm.test('Marking scheme has correct project ID', function () {",
                  "        var projectId = pm.environment.get('createdProjectId');",
                  "        pm.expect(scheme.projectId).to.equal(projectId);",
                  "    });",
                  "    ",
                  "    pm.test('Marking scheme has name', function () {",
                  "        pm.expect(scheme.name).to.be.a('string').and.not.empty;",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json, text/plain, */*"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/MarkingSchemes/project/{{createdProjectId}}?parentless=true",
              "host": ["{{baseUrl}}"],
              "path": ["api", "MarkingSchemes", "project", "{{createdProjectId}}"],
              "query": [
                { "key": "parentless", "value": "true" }
              ]
            }
          }
        },
        {
          "name": "TEARDOWN - DELETE /api/Projects/{id} (Delete project)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// =========================================",
                  "// TEARDOWN: Удаление созданного проекта",
                  "// =========================================",
                  "",
                  "var projectId = pm.environment.get('createdProjectId');",
                  "",
                  "if (projectId) {",
                  "    pm.test('Status 2xx - Проект удалён', function () {",
                  "        pm.expect(pm.response.code).to.be.at.least(200).and.below(300);",
                  "    });",
                  "    ",
                  "    console.log('Deleted project: ' + projectId);",
                  "    pm.environment.unset('createdProjectId');",
                  "    pm.environment.unset('createdMarkingSchemeId');",
                  "    pm.environment.unset('newProjectName');",
                  "    pm.environment.unset('runSuffix');",
                  "} else {",
                  "    pm.test('Skipped - нет созданного проекта', function () {",
                  "        pm.expect(true).to.be.true;",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Accept",
                "value": "application/json, text/plain, */*"
              }
            ],
            "url": "{{baseUrl}}/api/Projects/{{createdProjectId}}"
          }
        }
      ]
