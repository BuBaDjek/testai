{
  "info": {
    "_postman_id": "smart-ocr-test-001",
    "name": "Умный OCR - Создание проекта",
    "description": "Тест создания проекта для распознавания документов в утверждённой форме. Модуль: Проекты, Категория: Умный OCR",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// =========================================",
          "// АВТОНОМНАЯ АВТОРИЗАЦИЯ",
          "// Каждый тест независим - токен обновляется автоматически",
          "// =========================================",
          "",
          "// Инициализация переменных",
          "if (!pm.environment.get('runSuffix')) {",
          "    pm.environment.set('runSuffix', String(Date.now()));",
          "}",
          "",
          "var suffix = pm.environment.get('runSuffix');",
          "",
          "// Генерация уникального имени проекта",
          "if (!pm.environment.get('newProjectName')) {",
          "    pm.environment.set('newProjectName', 'autotest_ocr_' + suffix);",
          "}",
          "",
          "// Добавляем Authorization header если токен есть",
          "var token = pm.environment.get('token');",
          "if (token) {",
          "    pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + token });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Авто-логин",
      "item": [
        {
          "name": "POST /auth/account (Login)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// =========================================",
                  "// ТЕСТ АВТОРИЗАЦИИ",
                  "// =========================================",
                  "",
                  "pm.test('Status 200 - Успешная авторизация', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is JSON', function () {",
                  "    pm.expect(function () { pm.response.json(); }).to.not.throw();",
                  "});",
                  "",
                  "var json = pm.response.json();",
                  "",
                  "pm.test('Token exists in response', function () {",
                  "    pm.expect(json.token).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "// Сохраняем токен для следующих запросов",
                  "if (json.token) {",
                  "    pm.environment.set('token', json.token);",
                  "    console.log('Token saved: ' + json.token.substring(0, 30) + '...');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json, text/plain, */*"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Client-Type",
                "value": "Browser"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/auth/account"
          }
        }
      ]
    },
    {
      "name": "Проверка создания проекта (Распознавания документов в утверждённой форме)",
      "description": "Тест-кейс: Создание проекта для распознавания документов в утверждённой форме (Умный OCR)",
      "item": [
        {
          "name": "EXECUTE - POST /api/Projects (Create)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// =========================================",
                  "// EXECUTE: Создание проекта",
                  "// =========================================",
                  "",
                  "pm.test('Status 201 - Проект создан', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response contains project ID', function () {",
                  "    var responseText = pm.response.text();",
                  "    pm.expect(responseText).to.be.a('string').and.not.empty;",
                  "    ",
                  "    // Ответ - это просто ID проекта",
                  "    var projectId = parseInt(responseText, 10);",
                  "    pm.expect(projectId).to.be.a('number').and.above(0);",
                  "    ",
                  "    // Сохраняем ID для следующих запросов и TEARDOWN",
                  "    pm.environment.set('createdProjectId', projectId);",
                  "    console.log('Created project with ID: ' + projectId);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json, text/plain, */*"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{newProjectName}}\",\n  \"description\": \"Тестовый проект OCR для автотестов\",\n  \"component\": 0,\n  \"modelUsage\": 0\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/Projects"
          }
        },
        {
          "name": "VERIFY - GET /api/Projects/{id} (Get created project)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// =========================================",
                  "// VERIFY: Проверка созданного проекта",
                  "// =========================================",
                  "",
                  "pm.test('Status 200 - Проект найден', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is JSON', function () {",
                  "    pm.expect(function () { pm.response.json(); }).to.not.throw();",
                  "});",
                  "",
                  "var json = pm.response.json();",
                  "var projectName = pm.environment.get('newProjectName');",
                  "",
                  "pm.test('Project ID matches', function () {",
                  "    var createdId = pm.environment.get('createdProjectId');",
                  "    pm.expect(json.id).to.equal(createdId);",
                  "});",
                  "",
                  "pm.test('Project name matches', function () {",
                  "    pm.expect(json.name).to.equal(projectName);",
                  "});",
                  "",
                  "pm.test('Project description matches', function () {",
                  "    pm.expect(json.description).to.equal('Тестовый проект OCR для автотестов');",
                  "});",
                  "",
                  "pm.test('Component is 0 (Smart OCR)', function () {",
                  "    pm.expect(json.component).to.equal(0);",
                  "});",
                  "",
                  "pm.test('Model usage is 0', function () {",
                  "    pm.expect(json.smartOCRModelUsage).to.equal(0);",
                  "});",
                  "",
                  "pm.test('DataSet count is 0', function () {",
                  "    pm.expect(json.dataSetCount).to.equal(0);",
                  "});",
                  "",
                  "pm.test('freeDoc is false', function () {",
                  "    pm.expect(json.freeDoc).to.equal(false);",
                  "});"
                ]
              }
