{
  "info": {
    "_postman_id": "auth-test-001",
    "name": "00 - Авторизация",
    "description": "Модуль: Автотест авторизации на основе test.har",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// =========================================",
          "// АВТОНОМНАЯ АВТОРИЗАЦИЯ",
          "// Каждый тест независим - токен обновляется автоматически",
          "// =========================================",
          "",
          "// Инициализация переменных",
          "if (!pm.environment.get('runSuffix')) {",
          "    pm.environment.set('runSuffix', String(Date.now()));",
          "}",
          "",
          "var suffix = pm.environment.get('runSuffix');",
          "",
          "// Добавляем Authorization header если токен есть",
          "var token = pm.environment.get('token');",
          "if (token) {",
          "    pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + token });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Проверка доступности",
      "item": [
        {
          "name": "GET /login (Health Check)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 или 302', function () { ",
                  "    pm.expect([200, 302, 401, 403]).to.include(pm.response.code);",
                  "});",
                  "pm.test('Response time < 5000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(5000);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8"
              }
            ],
            "url": "{{baseUrl}}/login"
          }
        }
      ]
    },
    {
      "name": "Авторизация",
      "item": [
        {
          "name": "POST /auth/account (Login)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// =========================================",
                  "// ТЕСТ АВТОРИЗАЦИИ",
                  "// =========================================",
                  "",
                  "pm.test('Status 200 - Успешная авторизация', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is JSON', function () {",
                  "    pm.expect(function () { pm.response.json(); }).to.not.throw();",
                  "});",
                  "",
                  "var json = pm.response.json();",
                  "",
                  "pm.test('Token exists in response', function () {",
                  "    pm.expect(json.token).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "pm.test('fullName exists in response', function () {",
                  "    pm.expect(json.fullName).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "pm.test('isAdmin is boolean', function () {",
                  "    pm.expect(json.isAdmin).to.be.a('boolean');",
                  "});",
                  "",
                  "pm.test('permissions is array', function () {",
                  "    pm.expect(json.permissions).to.be.an('array');",
                  "});",
                  "",
                  "// Сохраняем токен для следующих запросов",
                  "if (json.token) {",
                  "    pm.environment.set('token', json.token);",
                  "    console.log('Token saved: ' + json.token.substring(0, 30) + '...');",
                  "}",
                  "",
                  "// Проверяем наличие accessToken в cookies",
                  "var accessTokenCookie = pm.cookies.get('accessToken');",
                  "pm.test('AccessToken cookie exists', function () {",
                  "    pm.expect(accessTokenCookie).to.exist;",
                  "});",
                  "",
                  "// Проверяем наличие refreshToken в cookies",
                  "var refreshTokenCookie = pm.cookies.get('refreshToken');",
                  "pm.test('RefreshToken cookie exists', function () {",
                  "    pm.expect(refreshTokenCookie).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json, text/plain, */*"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Client-Type",
                "value": "Browser"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/auth/account"
          }
        },
        {
          "name": "POST /auth/account (Invalid credentials)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// =========================================",
                  "// НЕГАТИВНЫЙ ТЕСТ - Неверные учетные данные",
                  "// =========================================",
                  "",
                  "pm.test('Status 401 - Unauthorized', function () {",
                  "    pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json, text/plain, */*"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Client-Type",
                "value": "Browser"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"invalid_user\",\n  \"password\": \"invalid_password\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/auth/account"
          }
        },
        {
          "name": "POST /auth/account (Empty credentials)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// =========================================",
                  "// НЕГАТИВНЫЙ ТЕСТ - Пустые учетные данные",
                  "// =========================================",
                  "",
                  "pm.test('Status 400 or 401 - Bad Request или Unauthorized', function () {",
                  "    pm.expect([400, 401]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json, text/plain, */*"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Client-Type",
                "value": "Browser"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"\",\n  \"password\": \"\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/auth/account"
          }
        }
      ]
    }
  ],
  "variable": []
}